# Copy to .env; never commit real .env. Values are safe placeholders.
TZ=Etc/UTC
STACK_MODE=lite
PROMETHEUS_RETENTION=7d
UPTIME_KUMA_PORT=3001
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
ADGUARD_ADMIN_PORT=3002
ADGUARD_DNS_PORT=5353
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=<CHANGE_ME_LONG_RANDOM_PASSWORD>
UPTIME_KUMA_IMAGE=louislam/uptime-kuma:2.4.0-slim
PROMETHEUS_IMAGE=prom/prometheus:v3.13.1
NODE_EXPORTER_IMAGE=prom/node-exporter:v1.12.1
GRAFANA_IMAGE=grafana/grafana:13.1.0
CADVISOR_IMAGE=google/cadvisor:v0.60.5
ADGUARD_HOME_IMAGE=adguard/adguardhome:v0.107.76
CROWDSEC_IMAGE=crowdsecurity/crowdsec:1.7.8-debian
