# Copy this file to .env, replace every <CHANGE_ME> value, and never commit .env.
# Image tags should be pinned to tested versions after the first validation.

TZ=Europe/Madrid

UPTIME_KUMA_PORT=3001
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
ADGUARD_ADMIN_PORT=3002
ADGUARD_DNS_PORT=5353
PROMETHEUS_RETENTION=15d

UPTIME_KUMA_IMAGE=louislam/uptime-kuma:2
PROMETHEUS_IMAGE=prom/prometheus:latest
NODE_EXPORTER_IMAGE=prom/node-exporter:latest
GRAFANA_IMAGE=grafana/grafana-oss:latest
CADVISOR_IMAGE=gcr.io/cadvisor/cadvisor:latest
ADGUARD_HOME_IMAGE=adguard/adguardhome:latest
CROWDSEC_IMAGE=crowdsecurity/crowdsec:latest

GRAFANA_ADMIN_USER=<CHANGE_ME>
GRAFANA_ADMIN_PASSWORD=<CHANGE_ME>
