# Local environment files and secrets
.env
**/.env
!**/.env.example
*.key
*.pem
*.p12
*.pfx
*.kdbx
*.ovpn

# Packet captures and local databases may contain hostnames, IPs, payloads or credentials
*.pcap
*.pcapng
*.cap
*.sqlite
*.sqlite3
*.db

# Runtime data, logs, backups, and screenshots
*.log
logs/
**/logs/
data/
**/data/
backups/
**/backups/
screenshots/
**/screenshots/

# Local deployment files created after review
deploy/crowdsec/acquis.yaml
deploy/prometheus/targets/*.yml
!deploy/prometheus/targets/.gitkeep
# Compose v2 local deployment state
!deploy/prometheus/targets/*.example.yml
*.bak

# Editor and operating-system artifacts
.vscode/
.idea/
.DS_Store
Thumbs.db
